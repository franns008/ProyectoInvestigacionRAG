# Copiar este archivo a .env y completar con los valores reales
DATABASE_USER=your_db_user
DATABASE_PASS=your_db_pass
PGVECTOR_USR=your_vdb_user
PGVECTOR_PASS=your_vdb_pass
PIPESERVER_KEY=your_pipeline_api_key

# Generación por API — Groq (obtené la key en https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key

# Puertos opcionales (defaults en docker-compose.yml)
# OLLAMA_PORT=11434
# DB_PORT=5432
# VDB_PORT=5433
# OWEBUI_PORT=8180
# PIPELINES_PORT=9099
