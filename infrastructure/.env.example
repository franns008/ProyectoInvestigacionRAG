# Copiar este archivo a .env.
#
# Para un arranque de desarrollo NO hace falta completar nada de acá salvo
# GROQ_API_KEY (y sólo si usás el modo de generación 'groq'). Todas las
# credenciales de abajo ya tienen DEFAULTS en docker-compose.yml; sólo
# descomentá y cambiá las que quieras overridear.

# --- Generación por API — Groq (ÚNICO obligatorio en modo groq) ---
# Obtené la key en https://console.groq.com/keys. En modo ollama podés dejarla vacía.
GROQ_API_KEY=your_groq_api_key

# --- Credenciales de servicios (OPCIONALES: si se omiten, se usan los defaults) ---
# DB de OpenWebUI (owebuidb)          default: owui / owui
# DATABASE_USER=owui
# DATABASE_PASS=owui
# pgvector (pgvdb) — OJO: deben coincidir con el string hardcodeado en
# src/pipeline/pipeline_ciberseguridad.py (avdbuser/avdbpass) si los cambiás.
# PGVECTOR_USR=avdbuser
# PGVECTOR_PASS=avdbpass
# Token interno OpenWebUI <-> pipelines  default: 0p3n-w3bui
# PIPESERVER_KEY=0p3n-w3bui

# Puertos opcionales (defaults en docker-compose.yml)
# OLLAMA_PORT=11434
# DB_PORT=5432
# VDB_PORT=5433
# OWEBUI_PORT=8180
# PIPELINES_PORT=9099

# --- Proveedor del LLM de generación (ver docs/modos_llm.md) ---
# groq   = generación por API Key (Groq). Requiere GROQ_API_KEY. Corre en CPU.
# ollama = generación local en Ollama (orientado a GPU Nvidia). No usa GROQ_API_KEY.
LLM_PROVIDER=groq
# Modelo del LLM. Vacío = default por proveedor.
#   groq   -> usa el default del pipeline (meta-llama/llama-4-scout-17b-16e-instruct)
#   ollama -> default qwen2.5:3b-instruct (~2 GB VRAM). Debe estar 'ollama pull'-eado.
LLM_MODEL=
